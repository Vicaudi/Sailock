<UserControl x:Class="Sailock.Views.ChangelogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackground}">

    <Grid>
        <Rectangle Fill="#000000" Opacity="0.75"/>

        <Border Background="{DynamicResource AppModalBackground}"
                BorderBrush="{DynamicResource ContrastBorderBrush}"
                BorderThickness="1"
                Width="600"
                MaxHeight="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="36,30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="HISTORIAL DE VERSIONES"
                               Foreground="{DynamicResource AppForeground}"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentVersion}"
                               Foreground="{DynamicResource AppAccent}"
                               FontFamily="/Fonts/#Supermolot Light"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Lista de versiones -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,24">

                                    <!-- Versión + fecha -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="v"
                                                   Foreground="{DynamicResource AppAccent}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="14"/>
                                        <TextBlock Text="{Binding Version}"
                                                   Foreground="{DynamicResource AppAccent}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="14"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding Date}"
                                                   Foreground="{DynamicResource AppForegroundDim}"
                                                   FontFamily="/Fonts/#Supermolot Light"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Añadido -->
                                    <ItemsControl ItemsSource="{Binding Added}"
                                                  Visibility="{Binding Added.Count,
                                                               Converter={StaticResource NullToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="+"
                                                               Foreground="#00FF41"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11"
                                                               Margin="0,0,8,0"
                                                               Width="12"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Corregido -->
                                    <ItemsControl ItemsSource="{Binding Fixed}"
                                                  Visibility="{Binding Fixed.Count,
                                                               Converter={StaticResource NullToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="✓"
                                                               Foreground="#00ab26"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11"
                                                               Margin="0,0,8,0"
                                                               Width="12"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource AppForegroundDim}"
                                                               FontFamily="/Fonts/#Supermolot Light"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Separador entre versiones -->
                                    <Rectangle Height="1"
                                               Fill="{DynamicResource ContrastSeparatorBrush}"
                                               Margin="0,16,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Botón cerrar -->
                <Button Grid.Row="2"
                        Content="CERRAR"
                        Width="120"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SailockButton}"
                        Command="{Binding CloseCommand}"
                        Margin="0,20,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>