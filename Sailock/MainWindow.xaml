<Window x:Class="Sailock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Sailock.ViewModels"
        Icon="/Resources/sailock.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        BorderThickness="0"
        BorderBrush="Transparent"
        Background="#000000"
        Title="Sailock"
        Height="720"
        Width="1280"
        MinHeight="500"
        MinWidth="900">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Grid Grid.Row="0"
              Background="#0A0A0A"
              MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="SAILOCK"
                       Foreground="#222222"
                       FontFamily="/Fonts/#JetBrains Mono"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Grid.Column="0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnMinimize" Content="─" Width="46" Height="32"
                        Click="BtnMinimize_Click" Style="{StaticResource WindowControlButton}"/>
                <Button x:Name="BtnMaximize" Content="□" Width="46" Height="32"
                        Click="BtnMaximize_Click" Style="{StaticResource WindowControlButton}"/>
                <Button x:Name="BtnClose"    Content="✕" Width="46" Height="32"
                        Click="BtnClose_Click" Style="{StaticResource WindowControlButton_Close}"/>
            </StackPanel>
        </Grid>

        <!-- Área principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar con escala igual al contenido -->
            <Border Grid.Column="0"
                    Background="#080808"
                    BorderBrush="#1A1A1A"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding SidebarVisibility}">
                <Border.LayoutTransform>
                    <ScaleTransform ScaleX="{DynamicResource GlobalScale}"
                                    ScaleY="{DynamicResource GlobalScale}"/>
                </Border.LayoutTransform>

                <Grid Width="220">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo con fondo ligeramente diferenciado -->
                    <Border Grid.Row="0"
                            Background="#0A0A0A"
                            BorderBrush="#1A1A1A"
                            BorderThickness="0,0,0,1"
                            Padding="24,20">
                        <Image Height="48"
                               Source="{Binding LogoSource}"
                               HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Navegación -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,8,0,0">

                        <!-- Separador visual antes de nav -->
                        <Button Content="{DynamicResource Nav_Dashboard}"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateDashboardCommand}"/>

                        <Button Content="{DynamicResource Nav_Generator}"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateGeneratorCommand}"/>

                        <Button Content="{DynamicResource Nav_Settings}"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateSettingsCommand}"/>

                    </StackPanel>

                    <!-- Zona inferior: versión + logout -->
                    <Border Grid.Row="2"
                            BorderBrush="#1A1A1A"
                            BorderThickness="0,1,0,0"
                            Padding="16,16">
                        <StackPanel>
                            <Button Content="{DynamicResource Nav_Logout}"
                                    Style="{StaticResource SailockButton}"
                                    Command="{Binding LogoutCommand}"
                                    Margin="0,0,0,12"/>

                            <!-- Versión -->
                            <TextBlock x:Name="VersionText"
                                   Foreground="#555555"
                                   FontSize="10"
                                   FontFamily="/Fonts/#JetBrains Mono"
                                   HorizontalAlignment="Center"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="VersionText_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}">
                <ContentControl.LayoutTransform>
                    <ScaleTransform ScaleX="{DynamicResource GlobalScale}"
                                    ScaleY="{DynamicResource GlobalScale}"/>
                </ContentControl.LayoutTransform>
            </ContentControl>
        </Grid>
    </Grid>
</Window>